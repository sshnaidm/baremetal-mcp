{
  "mcpServers": {
    "baremetal-mcp": {
      "type": "stdio",
      "command": "fastmcp",
      "args": ["run", "-t", "stdio", "main.py"],
      "env": {
        "GLOBAL_CONFIG": "${GLOBAL_CONFIG:-global_config.yaml}",
        "REDFISH_CONFIG": "${REDFISH_CONFIG:-redfish_servers.yaml}",
        "REDFISH_SECRETS": "${REDFISH_SECRETS:-redfish_secrets.yaml}",
        "ISOS_FILE": "${ISOS_FILE:-isos.yaml}"
      }
    }
  }
}
