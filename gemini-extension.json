{
  "name": "baremetal-mcp",
  "version": "1.0.0",
  "description": "An MCP server for managing bare-metal infrastructure — Redfish BMC operations and Junos switch queries.",
  "mcpServers": {
    "baremetal-mcp": {
      "command": "fastmcp",
      "args": [
        "run",
        "-t",
        "stdio",
        "${extensionPath}/main.py"
      ],
      "cwd": "${workspacePath}",
      "env": {
        "PYTHONPATH": "${extensionPath}"
      }
    }
  }
}
