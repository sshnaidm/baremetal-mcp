[flake8]
max-line-length = 120
max-complexity = 10

# Ignore specific errors (comments moved above for clarity)
# C901: is too complex
extend-ignore = C901

# Exclude directories
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .env,
    env,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .coverage

# Per-file ignores
#per-file-ignores =

# Show source code for each error
show-source = True

# Count errors
count = True

# Show statistics
statistics = True
